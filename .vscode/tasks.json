{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "install-deps",
            "type": "shell",
            "command": "npm",
            "args": ["install", "--legacy-peer-deps"],
            "group": "build",
            "options": {
                "cwd": "${workspaceFolder}/countries-app"
            }
        },
        {
            "label": "start-react",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "group": "build",
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}/countries-app"
            }
        }
    ]
}